# Backend environment variables (example)
# NOTE: Do not commit secrets in real deployments. The orchestrator will set .env.

# Server
HOST=0.0.0.0
PORT=3001
TRUST_PROXY=true

# CORS
ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization
CORS_MAX_AGE=3600

# Database
# Use the postgres connection string from task_management_database/db_connection.txt in local dev
DATABASE_URL=postgresql://appuser:dbuser123@localhost:5000/myapp

# JWT
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=60
